{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm build"
  },
  "deploy": {
    "preDeployCommand": ["pnpm prisma:deploy"],
    "startCommand": "pnpm railway:start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300
  }
}
